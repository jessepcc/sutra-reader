{
  "name": "sutra-reader",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "經閣 / Sutra Reader — a mobile-first PWA for the CBETA Chinese Buddhist canon.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
